module top_module ( 
    input p1a, p1b, p1c, p1d, p1e, p1f,
    output p1y,
    input p2a, p2b, p2c, p2d,
    output p2y );
wire x1;
wire x2;
assign x1 = p2a & p2b;
assign x2 = p2c & p2d;
assign p2y = x1 | x2;

    
wire x3;
wire x4;
assign x3 = p1a & p1c & p1b;
assign x4 = p1f & p1e & p1d;
assign p1y = x3 | x4;
    
endmodule
